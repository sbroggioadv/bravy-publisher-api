generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  EDITOR
}

enum Platform {
  INSTAGRAM
  LINKEDIN
  TIKTOK
  TWITTER
}

enum ContentType {
  CAROUSEL
  REEL
  STATIC
}

enum ContentStatus {
  DRAFT
  GENERATING
  READY
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

enum JobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum SlideType {
  COVER
  BODY
  CTA
}

enum TemplateFamily {
  STEP
  COMPENDIUM
  EDITORIAL
  TERMINAL
  SPLIT
  STATIC
}

model Tenant {
  id             String          @id @default(uuid())
  name           String
  slug           String          @unique
  timezone       String          @default("America/Sao_Paulo")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  users          User[]
  contents       Content[]
  socialAccounts SocialAccount[]

  @@map("tenants")
}

model User {
  id        String   @id @default(uuid())
  tenantId  String   @map("tenant_id")
  email     String   @unique
  password  String
  name      String
  role      Role     @default(EDITOR)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant    @relation(fields: [tenantId], references: [id])
  contents Content[]

  @@map("users")
}

model SocialAccount {
  id               String    @id @default(uuid())
  tenantId         String    @map("tenant_id")
  platform         Platform
  accountName      String    @map("account_name")
  accountId        String    @map("account_id")
  accessToken      String    @map("access_token")
  // Long-lived user access token (encrypted) — kept so the refresh cron can
  // re-derive a fresh Page Access Token without forcing the user to reconnect.
  userAccessToken  String?   @map("user_access_token")
  // Provider-side user id (e.g. Facebook user id) of whoever authorized the
  // app — useful for debug/diagnose endpoints.
  providerUserId   String?   @map("provider_user_id")
  tokenExpiresAt   DateTime? @map("token_expires_at")
  lastRefreshedAt  DateTime? @map("last_refreshed_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  publishTargets PublishTarget[]

  @@map("social_accounts")
}

model Template {
  id           String         @id @default(uuid())
  slug         String         @unique
  family       TemplateFamily
  persona      String?
  htmlContent  String         @map("html_content") @db.Text
  cssVariables Json?          @map("css_variables")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  contents     Content[]

  @@map("templates")
}

model Content {
  id          String        @id @default(uuid())
  tenantId    String        @map("tenant_id")
  slug        String
  contentType ContentType   @default(CAROUSEL) @map("content_type")
  status      ContentStatus @default(DRAFT)
  persona     String?
  pattern     String?
  template    String?
  hookCapa    String?       @map("hook_capa") @db.Text
  caption     String?       @db.Text
  slidesData  Json?         @map("slides_data")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  authorId       String?         @map("author_id")
  author         User?           @relation(fields: [authorId], references: [id])
  templateId     String?         @map("template_id")
  templateRef    Template?       @relation(fields: [templateId], references: [id])
  slides         Slide[]
  publishTargets PublishTarget[]
  generations    Generation[]
  renderJobs     RenderJob[]

  @@map("contents")
}

model Slide {
  id        String    @id @default(uuid())
  contentId String    @map("content_id")
  position  Int
  slideType SlideType @default(BODY) @map("slide_type")
  bodyData  Json      @map("body_data")
  imageUrl  String?   @map("image_url")
  imageKey  String?   @map("image_key")
  createdAt DateTime  @default(now()) @map("created_at")

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)

  @@map("slides")
}

model PublishTarget {
  id              String    @id @default(uuid())
  contentId       String    @map("content_id")
  socialAccountId String    @map("social_account_id")
  scheduledAt     DateTime? @map("scheduled_at")
  publishedAt     DateTime? @map("published_at")
  externalMediaId String?   @map("external_media_id")
  status          JobStatus @default(PENDING)
  attempts        Int       @default(0)
  lastError       String?   @map("last_error") @db.Text
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  content       Content       @relation(fields: [contentId], references: [id])
  socialAccount SocialAccount @relation(fields: [socialAccountId], references: [id])
  analytics     Analytics[]

  @@map("publish_targets")
}

model RenderJob {
  id        String    @id @default(uuid())
  contentId String    @map("content_id")
  status    JobStatus @default(PENDING)
  bullJobId String?   @map("bull_job_id")
  attempts  Int       @default(0)
  error     String?   @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  content Content @relation(fields: [contentId], references: [id])

  @@map("render_jobs")
}

model Generation {
  id           String   @id @default(uuid())
  contentId    String   @map("content_id")
  prompt       String   @db.Text
  response     Json
  model        String
  inputTokens  Int      @map("input_tokens")
  outputTokens Int      @map("output_tokens")
  durationMs   Int      @map("duration_ms")
  createdAt    DateTime @default(now()) @map("created_at")

  content Content @relation(fields: [contentId], references: [id])

  @@map("generations")
}

model DatasetEntry {
  id        String   @id @default(uuid())
  entryType String   @map("entry_type")
  code      String?
  persona   String?
  pattern   String?
  data      Json
  score     Float?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("dataset_entries")
}

model Analytics {
  id              String   @id @default(uuid())
  publishTargetId String   @map("publish_target_id")
  likes           Int      @default(0)
  comments        Int      @default(0)
  shares          Int      @default(0)
  saves           Int      @default(0)
  reach           Int      @default(0)
  impressions     Int      @default(0)
  engagementRate  Float?   @map("engagement_rate")
  fetchedAt       DateTime @default(now()) @map("fetched_at")

  publishTarget PublishTarget @relation(fields: [publishTargetId], references: [id])

  @@map("analytics")
}
